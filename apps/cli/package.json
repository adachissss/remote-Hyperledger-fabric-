    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@plus-fabric/shared": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
